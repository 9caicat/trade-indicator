/* ============ 变量 ============ */
:root {
    --bg-primary: #0a0e1a;
    --bg-secondary: #111827;
    --bg-card: #1a2235;
    --bg-card-hover: #222d44;
    --border-color: #2d3748;
    --text-primary: #e2e8f0;
    --text-secondary: #94a3b8;
    --text-muted: #64748b;
    --accent-primary: #3b82f6;
    --accent-secondary: #60a5fa;
    --success: #00c853;
    --warning: #ff9100;
    --danger: #ff1744;
    --radius: 12px;
    --radius-sm: 8px;
    --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 2px 4px -1px rgba(0, 0, 0, 0.2);
    --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
    --transition: all 0.3s ease;
}

/* ============ 重置与基础 ============ */
*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
    scroll-padding-top: 70px;
}

body {
    font-family: 'Inter', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
    background-color: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

a {
    color: var(--accent-primary);
    text-decoration: none;
    transition: var(--transition);
}

a:hover {
    color: var(--accent-secondary);
}

/* ============ 加载动画 ============ */
.loading-overlay {
    position: fixed;
    inset: 0;
    background: var(--bg-primary);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    transition: opacity 0.5s ease, visibility 0.5s ease;
}

.loading-overlay.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
}

.loading-spinner {
    width: 48px;
    height: 48px;
    border: 3px solid var(--border-color);
    border-top-color: var(--accent-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.loading-overlay p {
    margin-top: 16px;
    color: var(--text-secondary);
    font-size: 14px;
}

/* ============ 导航栏 ============ */
.navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: rgba(10, 14, 26, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    z-index: 1000;
}

.nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
}

.nav-icon {
    width: 24px;
    height: 24px;
    color: var(--accent-primary);
}

.nav-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.5px;
}

.nav-badge {
    font-size: 11px;
    font-weight: 600;
    color: var(--accent-primary);
    background: rgba(59, 130, 246, 0.15);
    padding: 2px 8px;
    border-radius: 100px;
    border: 1px solid rgba(59, 130, 246, 0.3);
}

.nav-links {
    display: flex;
    gap: 4px;
}

.nav-link {
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    transition: var(--transition);
}

.nav-link:hover,
.nav-link.active {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.08);
}

/* ============ Hero 区域 ============ */
.hero {
    padding: 100px 24px 48px;
    text-align: center;
    background: linear-gradient(180deg, rgba(59, 130, 246, 0.08) 0%, transparent 100%);
}

.hero-content h1 {
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -1px;
    background: linear-gradient(135deg, #e2e8f0 0%, #60a5fa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.hero-subtitle {
    margin-top: 12px;
    font-size: 16px;
    color: var(--text-secondary);
    font-weight: 400;
}

.hero-meta {
    margin-top: 20px;
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    font-size: 13px;
    color: var(--text-muted);
}

.update-time {
    display: flex;
    align-items: center;
    gap: 6px;
}

.update-time::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--success);
    border-radius: 50%;
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
}

/* ============ 容器 ============ */
.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px 60px;
}

.section {
    margin-bottom: 48px;
}

.section-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 24px;
}

.section-title svg {
    width: 22px;
    height: 22px;
    color: var(--accent-primary);
    flex-shrink: 0;
}

/* ============ 卡片网格 ============ */
.cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
}

.index-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 24px;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
}

.index-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--status-color, var(--accent-primary));
    opacity: 0.8;
}

.index-card:hover {
    transform: translateY(-2px);
    background: var(--bg-card-hover);
    box-shadow: var(--shadow-lg);
    border-color: rgba(255, 255, 255, 0.1);
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
}

.card-title {
    font-size: 18px;
    font-weight: 700;
}

.card-code {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 500;
    font-family: 'SF Mono', monospace;
}

.card-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 600;
    background: var(--status-bg, rgba(41, 121, 255, 0.15));
    color: var(--status-color, var(--accent-primary));
    border: 1px solid var(--status-border, rgba(41, 121, 255, 0.3));
}

.card-value {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -1px;
    margin: 8px 0;
    font-variant-numeric: tabular-nums;
}

.card-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--border-color);
}

.detail-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.detail-label {
    font-size: 12px;
    color: var(--text-muted);
}

.detail-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
}

.card-footer {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.percentile-bar {
    flex: 1;
    height: 4px;
    background: var(--border-color);
    border-radius: 100px;
    overflow: hidden;
    margin-right: 12px;
}

.percentile-fill {
    height: 100%;
    border-radius: 100px;
    background: linear-gradient(90deg, var(--success), var(--warning), var(--danger));
    transition: width 0.6s ease;
}

.percentile-text {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 500;
    white-space: nowrap;
}

/* 状态颜色 */
.status-diamond_bottom { --status-color: #00c853; --status-bg: rgba(0, 200, 83, 0.15); --status-border: rgba(0, 200, 83, 0.3); }
.status-dca { --status-color: #64dd17; --status-bg: rgba(100, 221, 23, 0.15); --status-border: rgba(100, 221, 23, 0.3); }
.status-equilibrium { --status-color: #2979ff; --status-bg: rgba(41, 121, 255, 0.15); --status-border: rgba(41, 121, 255, 0.3); }
.status-warm { --status-color: #ff9100; --status-bg: rgba(255, 145, 0, 0.15); --status-border: rgba(255, 145, 0, 0.3); }
.status-hot { --status-color: #ff1744; --status-bg: rgba(255, 23, 68, 0.15); --status-border: rgba(255, 23, 68, 0.3); }
.status-extreme_hot { --status-color: #b71c1c; --status-bg: rgba(183, 28, 28, 0.15); --status-border: rgba(183, 28, 28, 0.3); }

/* ============ 指数选择器 ============ */
.index-selector {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
}

.index-btn {
    padding: 8px 18px;
    border-radius: 100px;
    border: 1px solid var(--border-color);
    background: var(--bg-card);
    color: var(--text-secondary);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: var(--transition);
    font-family: inherit;
}

.index-btn:hover {
    border-color: var(--accent-primary);
    color: var(--text-primary);
}

.index-btn.active {
    background: var(--accent-primary);
    color: white;
    border-color: var(--accent-primary);
}

/* ============ 图表容器 ============ */
.chart-container {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 20px;
    margin-bottom: 16px;
}

.chart {
    width: 100%;
    height: 480px;
}

/* ============ 时间范围选择器 ============ */
.time-range-selector {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 12px;
}

.range-btn {
    padding: 6px 16px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
    background: transparent;
    color: var(--text-secondary);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: var(--transition);
    font-family: inherit;
}

.range-btn:hover {
    border-color: var(--accent-primary);
    color: var(--text-primary);
}

.range-btn.active {
    background: var(--accent-primary);
    color: white;
    border-color: var(--accent-primary);
}

/* ============ 信号统计 ============ */
.signals-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.signals-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 16px;
}

.stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 24px;
    text-align: center;
    transition: var(--transition);
}

.stat-card:hover {
    background: var(--bg-card-hover);
    border-color: rgba(255, 255, 255, 0.1);
}

.stat-value {
    font-size: 32px;
    font-weight: 800;
    color: var(--accent-primary);
    letter-spacing: -1px;
    font-variant-numeric: tabular-nums;
}

.stat-label {
    margin-top: 8px;
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
}

/* ============ 信号表格 ============ */
.signals-table-wrapper {
    overflow-x: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border-color);
}

.signals-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
}

.signals-table th,
.signals-table td {
    padding: 14px 16px;
    text-align: center;
    border-bottom: 1px solid var(--border-color);
}

.signals-table th {
    background: var(--bg-card);
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
}

.signals-table tbody tr {
    transition: var(--transition);
}

.signals-table tbody tr:hover {
    background: rgba(255, 255, 255, 0.03);
}

.signal-yes {
    color: var(--success);
    font-weight: 600;
}

.signal-no {
    color: var(--text-muted);
}

/* ============ 关于页面 ============ */
.about-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.about-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius);
    padding: 28px;
}

.about-card h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--text-primary);
}

.about-card p {
    color: var(--text-secondary);
    font-size: 14px;
    line-height: 1.7;
    margin-bottom: 12px;
}

.formula {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 20px;
    font-size: 18px;
    font-weight: 600;
    text-align: center;
    color: var(--accent-secondary);
    font-family: 'SF Mono', monospace;
    letter-spacing: 0.5px;
}

.formula sub {
    font-size: 12px;
}

.formula-params {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.param {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px;
    background: var(--bg-primary);
    border-radius: var(--radius-sm);
}

.param-name {
    font-weight: 700;
    color: var(--accent-primary);
    font-size: 14px;
    white-space: nowrap;
    min-width: 60px;
}

.param-desc {
    color: var(--text-secondary);
    font-size: 13px;
    line-height: 1.5;
}

/* 状态图例 */
.status-legend {
    display: flex;
    flex-direction: column;
    gap: 0;
}

.status-item {
    display: grid;
    grid-template-columns: 28px 80px 100px 1fr;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border-color);
    font-size: 14px;
}

.status-item:last-child {
    border-bottom: none;
}

.status-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    justify-self: center;
}

.status-name {
    font-weight: 600;
}

.status-range {
    color: var(--text-muted);
    font-size: 13px;
    font-family: 'SF Mono', monospace;
}

.status-action {
    color: var(--text-secondary);
    font-size: 13px;
}

/* 风险列表 */
.risk-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.risk-item {
    padding: 14px 16px;
    background: var(--bg-primary);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--warning);
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
}

.about-links {
    margin-top: 20px;
}

.about-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    transition: var(--transition);
}

.about-link:hover {
    border-color: var(--accent-primary);
    color: var(--text-primary);
    background: var(--bg-card-hover);
}

.about-link svg {
    width: 18px;
    height: 18px;
}

/* ============ 页脚 ============ */
.footer {
    border-top: 1px solid var(--border-color);
    padding: 40px 24px;
    text-align: center;
}

.footer-content p {
    color: var(--text-muted);
    font-size: 13px;
    margin-bottom: 6px;
}

.footer-disclaimer {
    font-size: 12px !important;
    opacity: 0.8;
}

.footer-auto {
    font-size: 11px !important;
    opacity: 0.6;
}

/* ============ 响应式 ============ */
@media (max-width: 768px) {
    .navbar {
        padding: 0 16px;
    }
    
    .nav-links {
        display: none;
    }
    
    .hero {
        padding: 80px 16px 32px;
    }
    
    .hero-content h1 {
        font-size: 28px;
    }
    
    .hero-subtitle {
        font-size: 14px;
    }
    
    .container {
        padding: 0 16px 40px;
    }
    
    .section-title {
        font-size: 18px;
    }
    
    .cards-grid {
        grid-template-columns: 1fr;
    }
    
    .chart {
        height: 320px;
    }
    
    .signals-stats {
        grid-template-columns: repeat(3, 1fr);
    }
    
    .stat-card {
        padding: 16px;
    }
    
    .stat-value {
        font-size: 24px;
    }
    
    .status-item {
        grid-template-columns: 24px 60px 80px 1fr;
        gap: 8px;
        font-size: 13px;
    }
    
    .formula {
        font-size: 14px;
        padding: 14px;
    }
    
    .about-card {
        padding: 20px;
    }
}

/* ============ 滚动条 ============ */
::-webkit-scrollbar {
    width: 8px;
    height: 8px;
}

::-webkit-scrollbar-track {
    background: var(--bg-primary);
}

::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: 100px;
}

::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
}
